{
  "name": "radius-scout",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:build": "vite build --watch --mode development",
    "dev:worker": "wait-on dist/index.html && wrangler dev --port 8799 --local-protocol=http",
    "dev": "concurrently -k -n BUILD,WORKER -c yellow,cyan \"npm:dev:build\" \"npm:dev:worker\"",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply radius-scout-db --local",
    "db:apply:remote": "wrangler d1 migrations apply radius-scout-db --remote",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_HEADLESS=false playwright test --headed",
    "test:e2e:capture": "CAPTURE_ONBOARDING=1 playwright test tests/e2e/onboarding-screenshots.spec.ts",
    "test:e2e:manual:capture": "CAPTURE_MANUAL=1 playwright test tests/e2e/manual-capture.spec.ts",
    "test:e2e:live:capture": "CAPTURE_ONBOARDING=1 PLAYWRIGHT_HEADLESS=false playwright test tests/e2e/onboarding-screenshots.spec.ts --headed",
    "test:e2e:live:manual:capture": "CAPTURE_MANUAL=1 PLAYWRIGHT_HEADLESS=false playwright test tests/e2e/manual-capture.spec.ts --headed",
    "test": "npm run test:unit && npm run test:e2e",
    "deploy": "npm run build && wrangler deploy",
    "smoke": "npm run test:e2e:live && npm run test:e2e:live:capture && npm run test:e2e:live:manual:capture",
    "setup": "bash scripts/setup.sh"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.1",
    "exifr": "^7.1.3",
    "hono": "^4.12.5",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.19.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4",
    "wrangler": "^4.71.0"
  }
}
